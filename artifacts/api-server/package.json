{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @workspace/db run migrate",
    "dev": "bash ../../scripts/dev-supervisor.sh api-server bash -c 'fuser -k $PORT/tcp 2>/dev/null || true; export NODE_ENV=development && pnpm run build && pnpm run start'",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "test": "BCRYPT_SALT_ROUNDS=4 bash ../../scripts/with-time-limit.sh 60000 bash scripts/run-tests-sharded.sh 2",
    "pretest:coverage": "pnpm --filter @workspace/api-spec run codegen",
    "test:coverage": "TEST_DB_ALLOW_EXIT_ON_IDLE=1 c8 node --import tsx/esm --test-isolation=none --test-concurrency=1 --test 'src/__tests__/**/*.test.ts'",
    "typecheck": "bash ../../scripts/with-time-limit.sh 60000 bash -c 'tsc -p tsconfig.json --noEmit && pnpm run check:cycles && pnpm run check:no-console'",
    "check:cycles": "node scripts/check-cycles.mjs",
    "check:no-console": "node scripts/check-no-console.mjs",
    "backfill:ai-memes": "tsx scripts/backfill-ai-memes.ts",
    "backfill:pexels": "tsx scripts/backfill-pexels.ts",
    "migrate:ai-backgrounds": "tsx scripts/migrate-ai-backgrounds.ts",
    "migrate:ai-backgrounds-v2": "tsx scripts/migrate-ai-backgrounds-v2.ts",
    "migrate:storage-keys": "tsx scripts/migrate-storage-keys.ts",
    "fix:ai-backgrounds-db": "tsx scripts/fix-ai-backgrounds-db.ts"
  },
  "dependencies": {
    "@fal-ai/client": "^1.9.5",
    "@google-cloud/storage": "^7.19.0",
    "@napi-rs/canvas": "^0.1.97",
    "@opentelemetry/api": "^1.9.1",
    "@sentry/node": "^10.49.0",
    "@types/bcryptjs": "^3.0.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-anthropic-ai": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "@workspace/redact": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "google-auth-library": "^10.6.2",
    "openai": "^6.33.0",
    "openid-client": "^6.8.2",
    "pino": "^9",
    "pino-http": "^10",
    "resend": "^6.9.4",
    "sharp": "^0.34.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@sentry/esbuild-plugin": "^5.2.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/supertest": "^7.2.0",
    "c8": "^10.1.3",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "madge": "^8.0.0",
    "pino-pretty": "^13",
    "supertest": "^7.2.2",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  },
  "c8": {
    "all": true,
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/__tests__/**",
      "src/data/seed-facts.ts",
      "src/instrument.ts",
      "src/**/*.d.ts"
    ],
    "extension": [
      ".ts"
    ],
    "reporter": [
      "text",
      "html",
      "json-summary"
    ],
    "reports-dir": "coverage"
  }
}
