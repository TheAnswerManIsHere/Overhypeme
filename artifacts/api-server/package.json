{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "backfill:ai-memes": "tsx scripts/backfill-ai-memes.ts",
    "backfill:pexels": "tsx scripts/backfill-pexels.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@napi-rs/canvas": "^0.1.97",
    "@types/bcryptjs": "^3.0.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-anthropic-ai": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "google-auth-library": "^10.6.2",
    "openai": "^6.33.0",
    "openid-client": "^6.8.2",
    "pino": "^9",
    "pino-http": "^10",
    "resend": "^6.9.4",
    "sharp": "^0.34.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
